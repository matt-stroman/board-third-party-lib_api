                }
              ],
              "cookie": [],
              "body": "{\n  \"status\": \"Healthy\",\n  \"checks\": [\n    {\n      \"name\": \"postgres\",\n      \"status\": \"Healthy\",\n      \"description\": \"PostgreSQL connection succeeded.\",\n      \"data\": {\n        \"database\": \"board_tpl\",\n        \"user\": \"board_tpl_user\"\n      }\n    }\n  ],\n  \"durationMs\": 6.1373\n}"
            },
            {
              "id": "b5167e37-8871-4d1b-be5f-25271bcf9168",
              "name": "API is running but not ready due to dependency failure.",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/health/ready",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "health",
                    "ready"
                  ]
                }
              },
              "status": "Service Unavailable",
              "code": 503,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "body": "{\n  \"status\": \"Unhealthy\",\n  \"checks\": [\n    {\n      \"name\": \"postgres\",\n      \"status\": \"Unhealthy\",\n      \"description\": \"PostgreSQL connection failed.\"\n    }\n  ],\n  \"durationMs\": 12.551\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "var expectedHttpStatusRaw = pm.environment.get(\"expectedReadyHttpStatus\") || \"200\";",
                  "var expectedHttpStatus = parseInt(expectedHttpStatusRaw, 10);",
                  "var expectedOverallStatus = pm.environment.get(\"expectedReadyStatus\") || \"Healthy\";",
                  "var expectedDatabase = pm.environment.get(\"expectedReadyDatabase\");",
                  "var expectedUser = pm.environment.get(\"expectedReadyUser\");",
                  "pm.test(\"Status code matches expected readiness response\", function () {",
                  "  pm.response.to.have.status(expectedHttpStatus);",
                  "});",
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "var json = pm.response.json();",
                  "var checks = Array.isArray(json.checks) ? json.checks : [];",
                  "var postgresCheck = checks.find(function (c) { return c && c.name === \"postgres\"; });",
                  "pm.test(\"Readiness status matches expected\", function () {",
                  "  pm.expect(json.status).to.eql(expectedOverallStatus);",
                  "});",
                  "pm.test(\"Postgres check is present\", function () {",
                  "  pm.expect(postgresCheck, \"postgres health check entry missing\").to.exist;",
                  "});",
                  "pm.test(\"durationMs is present\", function () {",
                  "  pm.expect(json.durationMs).to.be.a(\"number\");",
                  "});",
                  "if (expectedOverallStatus === \"Healthy\") {",
                  "  pm.test(\"Postgres check reports Healthy\", function () {",
                  "    pm.expect(postgresCheck.status).to.eql(\"Healthy\");",
                  "  });",
                  "  pm.test(\"Postgres data matches expected database and user\", function () {",
                  "    pm.expect(postgresCheck.data).to.be.an(\"object\");",
                  "    if (expectedDatabase) { pm.expect(postgresCheck.data.database).to.eql(expectedDatabase); }",
                  "    if (expectedUser) { pm.expect(postgresCheck.data.user).to.eql(expectedUser); }",
                  "  });",
                  "} else {",
                  "  pm.test(\"Postgres check is not healthy when readiness is not healthy\", function () {",
                  "    pm.expect([\"Unhealthy\", \"Degraded\"]).to.include(postgresCheck.status);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
