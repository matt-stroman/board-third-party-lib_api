    {
      "name": "Environments",
      "id": "a7fde8e9-951d-4e07-a1e4-8f4df2001a6d",
      "item": [
        {
          "name": "List environments and resolve Mock runtime environment ID",
          "id": "35f663f9-6ef3-41e3-84b6-7d04cfc68fef",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "var payload = pm.response.json();",
                  "var envs = (payload && payload.environments) || [];",
                  "var targetName = pm.environment.get(\"mockRuntimeEnvironmentName\") || \"Board Enthusiasts - Mock\";",
                  "var candidateNames = [targetName].filter(function (name) { return typeof name === \"string\" && name.trim().length > 0; }).map(function (name) { return name.trim(); });",
                  "var target = envs.find(function (e) { return e && candidateNames.indexOf(e.name) >= 0; });",
                  "pm.test(\"Mock runtime environment exists\", function () {",
                  "  pm.expect(target, \"Environment not found. Tried: \" + candidateNames.join(\", \")).to.exist;",
                  "});",
                  "if (target && target.id) { pm.environment.set(\"mockRuntimeEnvironmentId\", String(target.id)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{vault:postman-api-key}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{postmanApiBaseUrl}}/environments",
              "host": [
                "{{postmanApiBaseUrl}}"
              ],
              "path": [
                "environments"
              ]
            },
            "description": "Finds the Board Enthusiasts - Mock environment and stores its Postman environment ID in mockRuntimeEnvironmentId."
          },
          "response": []
        },
        {
          "name": "Sync Mock runtime environment baseUrl from mockUrl",
          "id": "cab02629-b7e6-4bd2-bebb-af956f184b6e",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "packages": {},
                "requests": {},
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "var payload = pm.response.json();",
                  "var envObj = payload && payload.environment;",
                  "var mockUrl = pm.environment.get(\"mockUrl\");",
                  "var apiBase = pm.environment.get(\"postmanApiBaseUrl\") || \"https://api.getpostman.com\";",
                  "var runtimeEnvId = pm.environment.get(\"mockRuntimeEnvironmentId\");",
                  "var apiKey = pm.variables.replaceIn(\"{{vault:postman-api-key}}\");",
                  "pm.test(\"Mock URL exists for sync\", function () { pm.expect(mockUrl).to.be.a(\"string\").and.to.not.eql(\"\"); });",
                  "pm.test(\"Runtime environment payload returned\", function () { pm.expect(envObj).to.exist; pm.expect(Array.isArray(envObj.values)).to.eql(true); });",
                  "if (!envObj || !Array.isArray(envObj.values) || !mockUrl || !runtimeEnvId || !apiKey || apiKey.indexOf(\"{{vault:\") === 0) { return; }",
                  "var values = envObj.values;",
                  "var baseVar = values.find(function (v) { return v && v.key === \"baseUrl\"; });",
                  "if (baseVar) { baseVar.value = mockUrl; } else { values.push({ key: \"baseUrl\", value: mockUrl, type: \"default\", enabled: true }); }",
                  "pm.sendRequest({",
                  "  url: apiBase + \"/environments/\" + runtimeEnvId,",
                  "  method: \"PUT\",",
                  "  header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" },",
                  "  body: { mode: \"raw\", raw: JSON.stringify({ environment: { name: envObj.name, values: values } }) }",
                  "}, function (err, res) {",
                  "  pm.test(\"Mock runtime environment baseUrl synced\", function () {",
                  "    pm.expect(err).to.eql(null);",
                  "    pm.expect(res).to.exist;",
                  "    pm.expect(res.code).to.eql(200);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{vault:postman-api-key}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{postmanApiBaseUrl}}/environments/{{mockRuntimeEnvironmentId}}",
              "host": [
                "{{postmanApiBaseUrl}}"
              ],
              "path": [
                "environments",
                "{{mockRuntimeEnvironmentId}}"
              ]
            },
            "description": "Fallback/manual helper that updates the Board Enthusiasts - Mock environment baseUrl to match mockUrl using the Postman API."
          },
          "response": []
        }
      ]
    }
