{
  "info": {
    "_postman_id": "2105612e-4326-4774-9d9e-fefa6f9767a9",
    "name": "Postman Admin - Board Enthusiasts Mock Provisioning",
    "description": "Provision and inspect the Postman mock server for the Board Enthusiasts contract tests using the Postman API. Use with the Board Enthusiasts - Mock Admin environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Collections",
      "item": [
        {
          "name": "Provision/refresh mock server (one-step)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "(async function () {",
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "var payload = pm.response.json();",
                  "var collections = (payload && payload.collections) || [];",
                  "var contractTestsName = pm.environment.get(\"contractTestsCollectionName\") || \"Board Enthusiasts API (Contract Tests)\";",
                  "var configuredMockSourceName = pm.environment.get(\"mockSourceCollectionName\");",
                  "var targetName = configuredMockSourceName || contractTestsName;",
                  "if (!configuredMockSourceName) { pm.environment.set(\"mockSourceCollectionName\", targetName); }",
                  "var targetPostmanId = pm.environment.get(\"mockSourceCollectionPostmanId\") || \"\";",
                  "var candidateNames = [targetName].filter(function (name) { return typeof name === \"string\" && name.trim().length > 0; }).map(function (name) { return name.trim(); });",
                  "var exactTarget = targetPostmanId ? collections.find(function (c) {",
                  "  return c && c.uid && c.uid.split(\"-\").slice(1).join(\"-\") === targetPostmanId;",
                  "}) : null;",
                  "var exactNameMatches = collections.filter(function (c) { return c && candidateNames.indexOf(c.name) >= 0; });",
                  "var generatedPrefixMatches = collections.filter(function (c) {",
                  "  return c && c.name && c.name.indexOf(\"Board Enthusiasts API (Generated\") === 0;",
                  "});",
                  "var prefixTarget = (!exactNameMatches.length && generatedPrefixMatches.length === 1) ? generatedPrefixMatches[0] : null;",
                  "var fallbackTarget = exactNameMatches[0] || prefixTarget || null;",
                  "var matchingByName = exactNameMatches;",
                  "var contractTestsMatches = collections.filter(function (c) { return c && c.name === contractTestsName; });",
                  "var contractTestsFallbackTarget = (!exactTarget && !fallbackTarget && contractTestsMatches.length === 1) ? contractTestsMatches[0] : null;",
                  "pm.test(\"Mock source collection name resolves to a usable workspace collection when no Postman ID is configured\", function () {",
                  "  if (targetPostmanId) { pm.expect(true).to.eql(true); return; }",
                  "  if (matchingByName.length === 1) { pm.expect(true).to.eql(true); return; }",
                  "  if (matchingByName.length === 0 && generatedPrefixMatches.length === 1) { pm.expect(true).to.eql(true); return; }",
                  "  if (matchingByName.length === 0 && contractTestsFallbackTarget) { pm.expect(true).to.eql(true); return; }",
                  "  var generatedCandidateNames = generatedPrefixMatches.map(function (c) { return c && c.name; }).filter(Boolean).join(\", \");",
                  "  var contractCandidateNames = contractTestsMatches.map(function (c) { return c && c.name; }).filter(Boolean).join(\", \");",
                  "  pm.expect(false, \"Found \" + matchingByName.length + \" collections named \" + targetName + \". Generated-prefix candidates: [\" + generatedCandidateNames + \"]. Contract Tests candidates: [\" + contractCandidateNames + \"]. Clean up duplicates or set mockSourceCollectionPostmanId.\").to.eql(true);",
                  "});",
                  "var target = exactTarget || fallbackTarget || contractTestsFallbackTarget;",
                  "if (!exactTarget && !fallbackTarget && contractTestsFallbackTarget) {",
                  "  pm.environment.set(\"mockSourceCollectionResolutionWarning\", \"Configured mock source collection not found in Postman API list; fell back to Contract Tests collection by name at \" + new Date().toISOString());",
                  "}",
                  "pm.test(\"Mock source collection name is configured\", function () {",
                  "  pm.expect(targetName).to.be.a(\"string\");",
                  "  pm.expect(targetName.trim().length).to.be.above(0);",
                  "});",
                  "pm.test(\"Mock source collection exists\", function () {",
                  "  pm.expect(target, \"Collection not found: \" + targetName + \". Ensure the mock source collection exists in Postman and is visible via the Postman API /collections endpoint, or set mockSourceCollectionPostmanId.\").to.exist;",
                  "});",
                  "pm.test(\"Resolved expected Mock source collection Postman ID when configured\", function () {",
                  "  if (!targetPostmanId) { pm.expect(true).to.eql(true); return; }",
                  "  if (exactTarget) { pm.expect(true).to.eql(true); return; }",
                  "  pm.expect(target, \"Expected collection Postman ID not found: \" + targetPostmanId + \". A fallback collection was also not available.\").to.exist;",
                  "});",
                  "if (target && target.uid && targetPostmanId && !exactTarget) {",
                  "  pm.environment.set(\"mockSourceCollectionResolutionWarning\", \"Name match used; exact Postman ID not found at \" + new Date().toISOString());",
                  "} else {",
                  "  if (!( !exactTarget && !fallbackTarget && contractTestsFallbackTarget)) { pm.environment.unset(\"mockSourceCollectionResolutionWarning\"); }",
                  "}",
                  "if (!target || !target.uid) { return; }",
                  "pm.environment.set(\"mockSourceCollectionUid\", target.uid);",
                  "if (target.name) { pm.environment.set(\"mockSourceCollectionName\", target.name); }",
                  "if (target.uid) {",
                  "  var resolvedPostmanId = String(target.uid).split(\"-\").slice(1).join(\"-\");",
                  "  if (resolvedPostmanId) { pm.environment.set(\"mockSourceCollectionPostmanId\", resolvedPostmanId); }",
                  "}",
                  "var apiBase = pm.environment.get(\"postmanApiBaseUrl\") || \"https://api.getpostman.com\";",
                  "var apiKey = null;",
                  "try {",
                  "  apiKey = await pm.vault.get(\"postman-api-key\");",
                  "} catch (vaultErr) {",
                  "  pm.test(\"Vault secret postman-api-key is accessible to scripts\", function () {",
                  "    pm.expect.fail(\"Enable Postman Vault support in scripts and grant this collection/workspace access to vault secrets.\");",
                  "  });",
                  "  return;",
                  "}",
                  "pm.test(\"Vault secret postman-api-key resolved for script requests\", function () {",
                  "  pm.expect(apiKey).to.be.a(\"string\");",
                  "  pm.expect(apiKey.length).to.be.above(0);",
                  "});",
                  "var workspaceId = pm.environment.get(\"workspaceId\");",
                  "var mockServerName = pm.environment.get(\"mockServerName\");",
                  "var runtimeEnvName = pm.environment.get(\"mockRuntimeEnvironmentName\") || \"Board Enthusiasts - Mock\";",
                  "var runtimeEnvNames = [runtimeEnvName].filter(function (name) { return typeof name === \"string\" && name.trim().length > 0; }).map(function (name) { return name.trim(); });",
                  "",
                  "function syncRuntimeEnvBaseUrl(mockUrl) {",
                  "  if (!mockUrl) { return; }",
                  "",
                  "  function doSync(envId) {",
                  "    if (!envId || !apiKey || apiKey.indexOf(\"{{vault:\") === 0) {",
                  "      pm.test(\"Runtime mock environment baseUrl auto-sync skipped (missing runtime env id or vault secret)\", function () {",
                  "        pm.expect(true).to.eql(true);",
                  "      });",
                  "      return;",
                  "    }",
                  "",
                  "    pm.sendRequest({",
                  "      url: apiBase + \"/environments/\" + envId,",
                  "      method: \"GET\",",
                  "      header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\" }",
                  "    }, function (getErr, getRes) {",
                  "      pm.test(\"Fetched runtime mock environment for baseUrl sync\", function () {",
                  "        pm.expect(getErr).to.eql(null);",
                  "        pm.expect(getRes).to.exist;",
                  "        pm.expect(getRes.code).to.eql(200);",
                  "      });",
                  "      if (getErr || !getRes || getRes.code !== 200) { return; }",
                  "",
                  "      var getPayload = getRes.json();",
                  "      var envObj = getPayload && getPayload.environment;",
                  "      pm.test(\"Runtime mock environment payload returned\", function () {",
                  "        pm.expect(envObj).to.exist;",
                  "        pm.expect(Array.isArray(envObj.values)).to.eql(true);",
                  "      });",
                  "      if (!envObj || !Array.isArray(envObj.values)) { return; }",
                  "",
                  "      var values = envObj.values;",
                  "      var baseVar = values.find(function (v) { return v && v.key === \"baseUrl\"; });",
                  "      if (baseVar) {",
                  "        baseVar.value = mockUrl;",
                  "      } else {",
                  "        values.push({ key: \"baseUrl\", value: mockUrl, type: \"default\", enabled: true });",
                  "      }",
                  "",
                  "      var putBody = { environment: { name: envObj.name || runtimeEnvName, values: values } };",
                  "      pm.sendRequest({",
                  "        url: apiBase + \"/environments/\" + envId,",
                  "        method: \"PUT\",",
                  "        header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" },",
                  "        body: { mode: \"raw\", raw: JSON.stringify(putBody) }",
                  "      }, function (putErr, putRes) {",
                  "        pm.test(\"Runtime mock environment baseUrl synced\", function () {",
                  "          pm.expect(putErr).to.eql(null);",
                  "          pm.expect(putRes).to.exist;",
                  "          pm.expect([200]).to.include(putRes.code);",
                  "        });",
                  "        if (!putErr && putRes && putRes.code === 200) {",
                  "          pm.environment.set(\"lastRuntimeMockEnvBaseUrlSyncAt\", new Date().toISOString());",
                  "        }",
                  "      });",
                  "    });",
                  "  }",
                  "",
                  "  if (!apiKey || apiKey.indexOf(\"{{vault:\") === 0) {",
                  "    pm.test(\"Runtime mock environment ID lookup skipped (missing vault secret)\", function () {",
                  "      pm.expect(true).to.eql(true);",
                  "    });",
                  "    return;",
                  "  }",
                  "",
                  "  pm.sendRequest({",
                  "    url: apiBase + \"/environments\",",
                  "    method: \"GET\",",
                  "    header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\" }",
                  "  }, function (envListErr, envListRes) {",
                  "    pm.test(\"Listed environments to resolve runtime mock environment ID\", function () {",
                  "      pm.expect(envListErr).to.eql(null);",
                  "      pm.expect(envListRes).to.exist;",
                  "      pm.expect(envListRes.code).to.eql(200);",
                  "    });",
                  "    if (envListErr || !envListRes || envListRes.code !== 200) { return; }",
                  "",
                  "    var envListPayload = envListRes.json();",
                  "    var envs = (envListPayload && envListPayload.environments) || [];",
                  "    var resolvedRuntimeEnvId = pm.environment.get(\"mockRuntimeEnvironmentId\") || \"\";",
                  "    var matchingByName = envs.filter(function (e) { return e && runtimeEnvNames.indexOf(e.name) >= 0; });",
                  "    var exactIdMatch = resolvedRuntimeEnvId ? envs.find(function (e) { return e && String(e.id) === resolvedRuntimeEnvId; }) : null;",
                  "    var runtimeEnv = null;",
                  "    if (exactIdMatch && runtimeEnvNames.indexOf(exactIdMatch.name) >= 0) {",
                  "      runtimeEnv = exactIdMatch;",
                  "    } else if (matchingByName.length === 1) {",
                  "      runtimeEnv = matchingByName[0];",
                  "    } else if (matchingByName.length > 1 && exactIdMatch && runtimeEnvNames.indexOf(exactIdMatch.name) >= 0) {",
                  "      runtimeEnv = exactIdMatch;",
                  "    } else if (matchingByName.length > 0) {",
                  "      runtimeEnv = matchingByName[0];",
                  "      pm.environment.set(\"mockRuntimeEnvironmentResolutionWarning\", \"Multiple runtime environments matched by name; using the first match at \" + new Date().toISOString());",
                  "    } else if (exactIdMatch) {",
                  "      runtimeEnv = exactIdMatch;",
                  "      pm.environment.set(\"mockRuntimeEnvironmentResolutionWarning\", \"Runtime environment name not found; fell back to stored Postman environment ID at \" + new Date().toISOString());",
                  "    } else {",
                  "      pm.environment.unset(\"mockRuntimeEnvironmentResolutionWarning\");",
                  "    }",
                  "    pm.test(\"Runtime mock environment exists for auto-sync\", function () {",
                  "      pm.expect(runtimeEnv, \"Environment not found. Tried: \" + runtimeEnvNames.join(\", \")).to.exist;",
                  "    });",
                  "    if (!runtimeEnv || !runtimeEnv.id) { return; }",
                  "",
                  "    pm.environment.set(\"mockRuntimeEnvironmentId\", String(runtimeEnv.id));",
                  "    if (runtimeEnvNames.indexOf(runtimeEnv.name) >= 0) { pm.environment.unset(\"mockRuntimeEnvironmentResolutionWarning\"); }",
                  "    doSync(String(runtimeEnv.id));",
                  "  });",
                  "}",
                  "",
                  "function createMockFromResolvedCollection() {",
                  "  pm.sendRequest({",
                  "    url: apiBase + \"/mocks?workspace=\" + encodeURIComponent(workspaceId || \"\"),",
                  "    method: \"POST\",",
                  "    header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" },",
                  "    body: {",
                  "      mode: \"raw\",",
                  "      raw: JSON.stringify({",
                  "        mock: {",
                  "          name: mockServerName,",
                  "          collection: target.uid,",
                  "          private: false",
                  "        }",
                  "      })",
                  "    }",
                  "  }, function (mockErr, mockRes) {",
                  "    pm.test(\"Create mock server response is 200 or 201\", function () {",
                  "      pm.expect(mockErr).to.eql(null);",
                  "      pm.expect(mockRes).to.exist;",
                  "      pm.expect([200, 201]).to.include(mockRes.code);",
                  "    });",
                  "    if (mockErr || !mockRes || [200, 201].indexOf(mockRes.code) < 0) { return; }",
                  "",
                  "    var mockPayload = mockRes.json();",
                  "    var mock = mockPayload && mockPayload.mock;",
                  "    pm.test(\"Mock object returned\", function () {",
                  "      pm.expect(mock).to.exist;",
                  "    });",
                  "    if (!mock) { return; }",
                  "",
                  "    if (mock.id) { pm.environment.set(\"mockId\", String(mock.id)); }",
                  "    var mockUrl = mock.mockUrl || mock.url || \"\";",
                  "    if (mockUrl) {",
                  "      pm.environment.set(\"mockUrl\", mockUrl);",
                  "      pm.environment.set(\"baseUrl\", mockUrl);",
                  "    }",
                  "",
                  "    syncRuntimeEnvBaseUrl(mockUrl);",
                  "  });",
                  "}",
                  "",
                  "function flattenRequests(items, acc) {",
                  "  acc = acc || [];",
                  "  (items || []).forEach(function (item) {",
                  "    if (!item) { return; }",
                  "    if (Array.isArray(item.item)) { flattenRequests(item.item, acc); return; }",
                  "    acc.push(item);",
                  "  });",
                  "  return acc;",
                  "}",
                  "",
                  "function requestPathRaw(reqItem) {",
                  "  if (!(reqItem && reqItem.request && reqItem.request.url)) { return \"\"; }",
                  "  var url = reqItem.request.url;",
                  "  if (url.raw) { return String(url.raw); }",
                  "  if (Array.isArray(url.path) && url.path.length) { return \"/\" + url.path.join(\"/\"); }",
                  "  if (typeof url.path === \"string\") { return url.path; }",
                  "  return \"\";",
                  "}",
                  "",
                  "function requestName(reqItem) {",
                  "  return reqItem && reqItem.name ? String(reqItem.name) : \"\";",
                  "}",
                  "",
                  "function requestMatches(reqItem, method, pathFragment, nameFragment) {",
                  "  if (!(reqItem && reqItem.request && reqItem.request.method === method)) { return false; }",
                  "  var pathRaw = requestPathRaw(reqItem).toLowerCase();",
                  "  var itemName = requestName(reqItem).toLowerCase();",
                  "  var normalizedPathFragment = (pathFragment || \"\").toLowerCase();",
                  "  var normalizedNameFragment = (nameFragment || \"\").toLowerCase();",
                  "  return (normalizedPathFragment && pathRaw.indexOf(normalizedPathFragment) >= 0) || (normalizedNameFragment && itemName.indexOf(normalizedNameFragment) >= 0);",
                  "}",
                  "",
                  "pm.sendRequest({",
                  "  url: apiBase + \"/collections/\" + encodeURIComponent(target.uid),",
                  "  method: \"GET\",",
                  "  header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\" }",
                  "}, function (detailErr, detailRes) {",
                  "  pm.test(\"Fetched resolved Mock source collection details\", function () {",
                  "    pm.expect(detailErr).to.eql(null);",
                  "    pm.expect(detailRes).to.exist;",
                  "    pm.expect(detailRes.code).to.eql(200);",
                  "  });",
                  "  if (detailErr || !detailRes || detailRes.code !== 200) { return; }",
                  "",
                  "  var detailPayload = detailRes.json();",
                  "  var collectionObj = detailPayload && detailPayload.collection;",
                  "  pm.test(\"Resolved Mock source collection payload returned\", function () {",
                  "    pm.expect(collectionObj).to.exist;",
                  "    pm.expect(Array.isArray(collectionObj.item)).to.eql(true);",
                  "  });",
                  "  if (!collectionObj || !Array.isArray(collectionObj.item)) { return; }",
                  "",
                  "  var requests = flattenRequests(collectionObj.item, []);",
                  "  var authConfigReq = requests.find(function (r) { return requestMatches(r, \"GET\", \"/identity/auth/config\", \"Get authentication configuration\"); });",
                  "  var loginReq = requests.find(function (r) { return requestMatches(r, \"GET\", \"/identity/auth/login\", \"Start browser login with Keycloak\"); });",
                  "  var currentUserReq = requests.find(function (r) { return requestMatches(r, \"GET\", \"/identity/me\", \"Get current user profile\"); });",
                  "",
                  "  pm.test(\"Resolved Mock source collection contains Keycloak auth routes\", function () {",
                  "    pm.expect(authConfigReq, \"Missing GET /identity/auth/config in resolved mock source collection snapshot (refresh the mock source collection/workspace object and retry)\").to.exist;",
                  "    pm.expect(loginReq, \"Missing GET /identity/auth/login in resolved mock source collection snapshot (refresh the mock source collection/workspace object and retry)\").to.exist;",
                  "    pm.expect(currentUserReq, \"Missing GET /identity/me in resolved mock source collection snapshot (refresh the mock source collection/workspace object and retry)\").to.exist;",
                  "  });",
                  "",
                  "  pm.test(\"Resolved Mock source collection contains saved mock responses for Keycloak auth routes\", function () {",
                  "    pm.expect(Array.isArray(authConfigReq && authConfigReq.response) && authConfigReq.response.length > 0, \"No saved examples on GET /identity/auth/config in resolved mock source collection (refresh the mock source collection/workspace object and retry)\").to.eql(true);",
                  "    pm.expect(Array.isArray(loginReq && loginReq.response) && loginReq.response.length > 0, \"No saved examples on GET /identity/auth/login in resolved mock source collection (refresh the mock source collection/workspace object and retry)\").to.eql(true);",
                  "    pm.expect(Array.isArray(currentUserReq && currentUserReq.response) && currentUserReq.response.length > 0, \"No saved examples on GET /identity/me in resolved mock source collection (refresh the mock source collection/workspace object and retry)\").to.eql(true);",
                  "  });",
                  "",
                  "  createMockFromResolvedCollection();",
                  "});",
                  "})();"
                ]
              }
            }
          ],
          "id": "e002704c-341a-4a3f-becf-9ac4ccc6170b",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{vault:postman-api-key}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{postmanApiBaseUrl}}/collections",
              "host": [
                "{{postmanApiBaseUrl}}"
              ],
              "path": [
                "collections"
              ]
            },
            "description": "One-step admin request that resolves the mock source collection UID (default: Contract Tests collection), validates the resolved collection snapshot contains expected routes/examples, creates a new mock server from it, stores mockId/mockUrl, and attempts to auto-sync the Board Enthusiasts - Mock environment baseUrl. Use the Board Enthusiasts - Mock Admin environment."
          },
          "response": []
        }
      ],
      "id": "5dcfd7ed-6e3e-4d61-8e27-515f3dc5f960"
    },
    {
      "name": "Mocks",
      "item": [
        {
          "name": "Create mock server (Contract Tests collection)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "var payload = pm.response.json();",
                  "var mock = payload && payload.mock;",
                  "pm.test(\"Mock object returned\", function () {",
                  "  pm.expect(mock).to.exist;",
                  "});",
                  "if (mock) {",
                  "  if (mock.id) { pm.environment.set(\"mockId\", String(mock.id)); }",
                  "  var mockUrl = mock.mockUrl || mock.url || \"\";",
                  "  if (mockUrl) {",
                  "    pm.environment.set(\"mockUrl\", mockUrl);",
                  "    pm.environment.set(\"baseUrl\", mockUrl);",
                  "  }",
                  "}",
                  "var runtimeEnvId = pm.environment.get(\"mockRuntimeEnvironmentId\");",
                  "var runtimeEnvName = pm.environment.get(\"mockRuntimeEnvironmentName\") || \"Board Enthusiasts - Mock\";",
                  "var apiBase = pm.environment.get(\"postmanApiBaseUrl\") || \"https://api.getpostman.com\";",
                  "var apiKey = pm.variables.replaceIn(\"{{vault:postman-api-key}}\");",
                  "if (mockUrl && runtimeEnvId && apiKey && apiKey.indexOf(\"{{vault:\") !== 0) {",
                  "  pm.sendRequest({",
                  "    url: apiBase + \"/environments/\" + runtimeEnvId,",
                  "    method: \"GET\",",
                  "    header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\" }",
                  "  }, function (getErr, getRes) {",
                  "    pm.test(\"Fetched runtime mock environment for baseUrl sync\", function () {",
                  "      pm.expect(getErr).to.eql(null);",
                  "      pm.expect(getRes).to.exist;",
                  "      pm.expect(getRes.code).to.eql(200);",
                  "    });",
                  "    if (getErr || !getRes || getRes.code !== 200) { return; }",
                  "    var getPayload = getRes.json();",
                  "    var envObj = getPayload && getPayload.environment;",
                  "    pm.test(\"Runtime mock environment payload returned\", function () {",
                  "      pm.expect(envObj).to.exist;",
                  "      pm.expect(Array.isArray(envObj.values)).to.eql(true);",
                  "    });",
                  "    if (!envObj || !Array.isArray(envObj.values)) { return; }",
                  "    var values = envObj.values;",
                  "    var baseVar = values.find(function (v) { return v && v.key === \"baseUrl\"; });",
                  "    if (baseVar) {",
                  "      baseVar.value = mockUrl;",
                  "    } else {",
                  "      values.push({ key: \"baseUrl\", value: mockUrl, type: \"default\", enabled: true });",
                  "    }",
                  "    var putBody = { environment: { name: envObj.name || runtimeEnvName, values: values } };",
                  "    pm.sendRequest({",
                  "      url: apiBase + \"/environments/\" + runtimeEnvId,",
                  "      method: \"PUT\",",
                  "      header: { \"X-Api-Key\": apiKey, \"Accept\": \"application/json\", \"Content-Type\": \"application/json\" },",
                  "      body: { mode: \"raw\", raw: JSON.stringify(putBody) }",
                  "    }, function (putErr, putRes) {",
                  "      pm.test(\"Runtime mock environment baseUrl synced\", function () {",
                  "        pm.expect(putErr).to.eql(null);",
                  "        pm.expect(putRes).to.exist;",
                  "        pm.expect([200]).to.include(putRes.code);",
                  "      });",
                  "      if (!putErr && putRes && putRes.code === 200) {",
                  "        pm.environment.set(\"lastRuntimeMockEnvBaseUrlSyncAt\", new Date().toISOString());",
                  "      }",
                  "    });",
                  "  });",
                  "} else {",
                  "  pm.test(\"Runtime mock environment baseUrl auto-sync skipped (missing mockUrl/runtime env id/vault secret)\", function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "id": "837ac082-9a24-439e-970f-93aec1956e12",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{vault:postman-api-key}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
